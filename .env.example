# Wubeté Hotel — Environment Variables Template
# Copy this file to .env and fill in your actual values.
# NEVER commit your real .env file to version control.

# ── Supabase (safe to keep in client — anon key is designed to be public) ──
VITE_SUPABASE_URL=https://your-project-id.supabase.co
VITE_SUPABASE_ANON_KEY=your_anon_key_here

# ── Admin Account ──
VITE_HOTEL_EMAIL=admin@yourhotel.com

# ── Hotel Contact Info (displayed in UI) ──
VITE_HOTEL_PHONE=+251 XX XXX XXXX

# ── Live Chat (Tawk.to — public widget IDs, safe in client) ──
VITE_TAWK_PROPERTY_ID=your_tawk_property_id
VITE_TAWK_WIDGET_ID=your_tawk_widget_id

# ── Chapa Payment (PUBLIC key only — used for display, not API calls) ──
VITE_CHAPA_PUBLIC_KEY=CHAPUBK_your_public_key

# ─────────────────────────────────────────────────────────────────────────────
# ⚠️  SECRET KEYS — DO NOT PUT THESE IN CLIENT ENV (VITE_ PREFIX)
#
# The following keys must ONLY be set as Supabase Edge Function secrets.
# Run: supabase secrets set KEY_NAME=value
#
# CHAPA_SECRET_KEY=CHASECK_your_secret_key
# RESEND_API_KEY=re_your_resend_api_key
# TELEGRAM_BOT_TOKEN=your_telegram_bot_token
# TELEGRAM_CHAT_ID=your_chat_id
# HOTEL_EMAIL=admin@yourhotel.com
#
# To set them: supabase secrets set CHAPA_SECRET_KEY=CHASECK_xxx
# ─────────────────────────────────────────────────────────────────────────────
